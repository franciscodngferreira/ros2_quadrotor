<?xml version="1.0"?>

<!-- Minimal GUI layout for recorded demos, used by scripts/record_demo.py.

     Gazebo cannot render the scene headlessly on WSL (no /dev/dri — the camera
     sensor renders empty frames under both ogre2 and ogre1), but the GUI client
     renders fine through WSLg's /dev/dxg. So demos are captured by screen-grabbing
     this window with ffmpeg x11grab rather than from a camera sensor in the world.

     Everything not needed for the shot is stripped (toolbars, inspector, entity
     tree, world control) so the window is almost entirely 3D view and needs no
     cropping. quick_start and dialog_on_exit are off — either would block an
     unattended run behind a dialog.

     Camera frames the flight volume: legs start at the +/-2 m corners and target
     points sit between z 0.8-1.9 m.
-->

<dialog name="quick_start" show_again="false"/>

<window>
  <width>1280</width>
  <height>720</height>
  <menus>
    <drawer default="false">
    </drawer>
  </menus>
  <dialog_on_exit>false</dialog_on_exit>
</window>

<!-- 3D scene -->
<plugin filename="MinimalScene" name="3D View">
  <gz-gui>
    <title>3D View</title>
    <property type="bool" key="showTitleBar">false</property>
    <property type="string" key="state">docked</property>
  </gz-gui>

  <engine>ogre2</engine>
  <scene>scene</scene>
  <ambient_light>0.4 0.4 0.4</ambient_light>
  <background_color>0.8 0.8 0.8</background_color>
  <!-- Moved in along the original view ray (60% of the old distance to the
       volume centre), so pitch/yaw are unchanged and only the framing tightens:
       the drone renders 1.67x larger. Closing further crops the legs' +/-2 m
       spawn corners — at 50% they need 29.7 deg of a 30 deg half-FOV. -->
  <camera_pose>-4.2 -4.2 3.5 0 0.357 0.785</camera_pose>
</plugin>

<!-- Keeps the scene populated from the server's ECM -->
<plugin filename="GzSceneManager" name="Scene Manager">
  <gz-gui>
    <property key="resizable" type="bool">false</property>
    <property key="width" type="double">5</property>
    <property key="height" type="double">5</property>
    <property key="state" type="string">floating</property>
    <property key="showTitleBar" type="bool">false</property>
  </gz-gui>
</plugin>

<plugin filename="InteractiveViewControl" name="Interactive view control">
  <gz-gui>
    <property key="resizable" type="bool">false</property>
    <property key="width" type="double">5</property>
    <property key="height" type="double">5</property>
    <property key="state" type="string">floating</property>
    <property key="showTitleBar" type="bool">false</property>
  </gz-gui>
</plugin>

<plugin filename="CameraTracking" name="Camera Tracking">
  <gz-gui>
    <property key="resizable" type="bool">false</property>
    <property key="width" type="double">5</property>
    <property key="height" type="double">5</property>
    <property key="state" type="string">floating</property>
    <property key="showTitleBar" type="bool">false</property>
  </gz-gui>
</plugin>

<!-- Video recorder. Its toolbar button is the ONLY capture path that works on
     this machine, so it has to be clicked by hand — the plugin advertises no
     service, and every unattended alternative was tried and failed:
       * camera sensor + CameraVideoRecorder -> uniformly blank frames (WSL has
         no /dev/dri, so the server renders nothing headlessly; ogre2 and ogre1
         both fail this way).
       * ffmpeg x11grab / mss screen capture -> pure black, because WSLg
         composites through Wayland and the X root window holds no content.
     The GUI itself renders fine via /dev/dxg, and this plugin reads back from
     its render target, which is why the button works where the rest do not. -->
<plugin filename="VideoRecorder" name="VideoRecorder">
  <gz-gui>
    <property key="resizable" type="bool">false</property>
    <property key="x" type="double">0</property>
    <property key="y" type="double">0</property>
    <property key="width" type="double">50</property>
    <property key="height" type="double">50</property>
    <property key="state" type="string">floating</property>
    <property key="showTitleBar" type="bool">false</property>
    <property key="cardBackground" type="string">#777777</property>
  </gz-gui>

  <record_video>
    <use_sim_time>true</use_sim_time>
    <lockstep>false</lockstep>
    <bitrate>4000000</bitrate>
  </record_video>
</plugin>
